-- smear-cursor 插件启用
require("smear_cursor").setup({
	-- 通用配置，使光标涂抹效果更活跃
	enabled = false, -- 启用涂抹效果
	smear_between_buffers = false, -- 在缓冲区之间切换时涂抹
	smear_between_neighbor_lines = true, -- 在相邻行之间移动时涂抹
	smear_to_cmd = true, -- 进入或退出命令行模式时涂抹
	smear_insert_mode = true, -- 在插入模式下涂抹
	smear_replace_mode = true, -- 在替换模式下涂抹
	smear_visual_mode = false,

	-- 涂抹的最大长度
	cursor_color = "#d3cdc3",

	max_smear_length = 120, -- 增加最大涂抹长度以适应宽屏显示器

	-- 特定模式配置
	modes = {
		normal = { enabled = true, smear_length = 40 },
		insert = { enabled = true, smear_length = 20 },
		visual = { enabled = false },
		replace = { enabled = true, smear_length = 10 },
		command = { enabled = true, smear_length = 30 },
	},

	opts = {
		stiffness = 0.5,
		trailing_stiffness = 0.5,
		matrix_pixel_threshold = 0.5,
		legacy_computing_symbols_support = true,
	},
})

require("auto-save").setup({
	enabled = true, -- 开启自动保存功能
	execution_message = {
		message = function()
			return "自动保存完成"
		end,
		dim = 0.18,
		cleaning_interval = 1250,
	},
	trigger_events = { "InsertLeave" }, -- 在插入模式离开和文本更改时触发保存
	debounce_delay = 135, -- 防抖延迟，单位为毫秒
	conditions = {
		exists = true,
		filetype_is_not = {},
		modifiable = true,
	},
	write_all_buffers = false, -- 仅保存当前缓冲区
	on_off_commands = true, -- 启用开关命令
	execution_message_on_off = true, -- 启用开关消息
})

-- ========================
-- indent-blankline.nvim (ibl.nvim) 配置
-- ========================
local highlight = {
	"BlueLight", -- 浅蓝
	"Blue", -- 天蓝
	"Cobalt", -- 钴蓝
	"Indigo", -- 靛蓝
	"Violet", -- 紫罗兰
	"Purple", -- 紫色
	"DeepPurple", -- 深紫
}

local hooks = require("ibl.hooks")
-- 每次配色方案变化时重置高亮组
hooks.register(hooks.type.HIGHLIGHT_SETUP, function()
	-- 蓝紫渐变配色（从浅蓝到深紫）
	vim.api.nvim_set_hl(0, "BlueLight", { fg = "#8AB4F8" }) -- 浅蓝（类似 Git 浅蓝色）
	vim.api.nvim_set_hl(0, "Blue", { fg = "#61AFEF" }) -- 天蓝（原配置的蓝色）
	vim.api.nvim_set_hl(0, "Cobalt", { fg = "#5C6BC0" }) -- 钴蓝
	vim.api.nvim_set_hl(0, "Indigo", { fg = "#7986CB" }) -- 靛蓝
	vim.api.nvim_set_hl(0, "Violet", { fg = "#9C27B0" }) -- 紫罗兰
	vim.api.nvim_set_hl(0, "Purple", { fg = "#BA68C0" }) -- 淡紫
	vim.api.nvim_set_hl(0, "DeepPurple", { fg = "#AB47B0" }) -- 深紫
end)

require("ibl").setup({
	indent = { highlight = highlight },
	-- 可选：如果需要更细的缩进线，可添加以下配置
