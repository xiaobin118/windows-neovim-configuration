require("nvim-highlight-colors").setup({
	-- How to render the color preview.
	-- 'background': Changes the background of the text. (Most common)
	-- 'foreground': Changes the color of the text itself.
	-- 'virtual':    Adds a colored square icon next to the code.
	render = "background",

	-- A list of filetypes where the plugin should be active.
	-- You can add or remove filetypes as you need.
	-- Using {'*'} would enable it for all filetypes.
	filetypes = {
		"css",
		"html",
		"javascript",
		"javascriptreact",
		"vue",
		"lua",
	},

	-- Enable highlighting for color names like "blue", "red", "white".
	enable_named_colors = true,

	-- Enable highlighting for Tailwind CSS classes like "bg-blue-500".
	-- Set this to false if you don't use Tailwind.
	enable_tailwind = true,
})

