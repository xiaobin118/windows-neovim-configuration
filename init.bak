-- ========================
-- Telescope 快捷键映射
-- ========================
-- local opts = { noremap = true, silent = false }
local actions = require('telescope.actions')
require("telescope").load_extension("fzf")
require("telescope").setup({
	defaults = {
		file_sorter = require("telescope.sorters").get_fzf_sorter,
		generic_sorter = require("telescope.sorters").get_fzf_sorter,
		set_env = { CONFIRM = false },
		prompt_prefix = "🔍 ",
        mappings = {
            i = {
                ["jw"] = actions.close,
            }
        },
		color_devicons = true,
		layout_strategy = "horizontal", -- 全局默认布局仍为 horizontal
		-- 重新组织 layout_config：按不同策略拆分，避免参数冲突
		layout_config = {
			-- 1. 全局通用参数（所有布局都支持）
			preview_cutoff = 1,
			prompt_position = "top",
			height = 0.6,
			width = 100,

			-- 2. 各布局的专属配置（只写该策略支持的参数）
			bottom_pane = {
				height = 0.6,
				preview_cutoff = 1,
				prompt_position = "top",
			},
			-- ❗ center 策略：移除 preview_width（不支持）
			center = {
				height = 0.6,
				preview_cutoff = 1,
				prompt_position = "top",
				width = 100,
			},
			cursor = {
				height = 0.6,
				preview_cutoff = 1,
				width = 100,
			},
			--  horizontal 策略：保留 preview_width（支持）
			horizontal = {
				height = 0.6,
				preview_cutoff = 1,
				prompt_position = "top",
				width = 100,
				preview_width = 0.6, -- 仅在 horizontal 中配置
			},
			--  vertical 策略：保留 preview_width（支持）
			vertical = {
				height = 0.6,
				preview_cutoff = 1,
				prompt_position = "top",
				width = 100,
				preview_width = 0.6, -- 仅在 vertical 中配置
			},
		},
		winblend = 0,
		border = {},
