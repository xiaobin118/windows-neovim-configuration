-- =========================
-- 新建文件自动插入文件头（重写版）
-- =========================

local function set_title()
	-- 仅对新建或空缓冲区文件插入头部
	local lines = vim.api.nvim_buf_get_lines(0, 0, -1, false)
	if #lines > 0 and not (#lines == 1 and lines[1] == "") then
		return
	end

	local fname = vim.fn.expand("%:t")
	local fname_r = vim.fn.expand("%:r")
	local ext = vim.fn.expand("%:e")
	local ft = vim.bo.filetype

	-- 跳过特殊类型
	-- 优先通过扩展名判定文件类型
	if ext == "py" then
		ft = "python"
	elseif ext == "sh" then
		ft = "sh"
	elseif ext == "rb" then
		ft = "ruby"
	elseif ext == "java" then
		ft = "java"
	end

	local header = {}

	if ft == "python" then
		header = {
			"#!/usr/bin/env python",
			"# coding=utf-8",
			"",
		}
	elseif ft == "sh" then
		header = {
			"#!/bin/bash",
			"",
		}
	elseif ft == "ruby" then
		header = {
			"#!/usr/bin/env ruby",
			"# encoding: utf-8",
			"",
		}
		-- 其他类型可添加通用头部（如有需要可取消注释）
	elseif ft == "c" or ft == "cpp" then
		header = {
			"/*************************************************************************",
			"        > File Name: " .. fname,
			"      > Author: xiaobin118",
			"      > Mail: 3350844208@qq.com",
			"      > Created Time: " .. os.date("%c"),
			" ************************************************************************/",
			"",
		}
	end

	-- 插入文件头
	vim.api.nvim_buf_set_lines(0, 0, -1, false, header)

	-- 附加不同语言模板
	if ext == "cpp" then
		vim.api.nvim_buf_set_lines(0, -1, -1, false, {
			"#include<iostream>",
			"using namespace std;",
			"",
		})
	elseif ext == "c" then
		vim.api.nvim_buf_set_lines(0, -1, -1, false, {
			"#include<stdio.h>",
			"",
		})
	elseif ext == "h" then
		vim.api.nvim_buf_set_lines(0, -1, -1, false, {
			"#ifndef _" .. string.upper(fname_r) .. "_H",
			"#define _" .. string.upper(fname_r) .. "_H",
			"#endif",
		})
	elseif ft == "java" then
		vim.api.nvim_buf_set_lines(0, -1, -1, false, {
			"public class " .. fname_r,
			"",
		})
	end

	-- 光标移动到文件末尾
	vim.cmd("normal! G")
end

vim.api.nvim_create_autocmd("BufNewFile", {
	pattern = "*",
	callback = set_title,
})
