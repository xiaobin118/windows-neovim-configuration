vim.keymap.set("v", "<C-c>", '"+y', { noremap = true, silent = true })
-- 鼠标支持
vim.o.mouse = "v"
-- F2 删除空行
vim.keymap.set("v", "<F2>", ":g/^\\s*$/d<CR>", { noremap = true, silent = true })
-- Ctrl+F2 垂直分屏比较文件
vim.keymap.set("n", "<C-F2>", ":vert diffsplit<CR>", { noremap = true, silent = true })

-- =========================
-- F6 快捷键：格式化当前文件
-- =========================
local function format_src()
vim.cmd("write") -- 保存文件
local ft = vim.bo.filetype
local file = vim.fn.expand("%")

if ft == "c" then
vim.cmd("!astyle --style=gnu --suffix=none " .. file)
elseif ft == "cpp" or ft == "hpp" then
-- 使用 clang-format 代替 astyle
vim.cmd("!clang-format -i " .. file)
elseif ft == "perl" then
vim.cmd("!astyle --style=gnu --suffix=none " .. file)
elseif ft == "py" or ft == "python" then
-- in windows
vim.cmd("!autopep8 --in-place --aggressive --aggressive " .. file)
elseif ft == "java" then
vim.cmd("!astyle --style=java --suffix=none " .. file)
elseif ft == "jsp" or ft == "xml" then
vim.cmd("!astyle --style=gnu --suffix=none " .. file)
else
vim.cmd("normal! gg=G") -- 普通格式化
return
end

-- 重新加载文件
vim.cmd("edit!")
end

vim.keymap.set("n", "<F6>", format_src, { noremap = true, silent = true })

-- =========================
-- JavaScript 文件智能识别为 JSX
-- ========================
vim.api.nvim_create_autocmd({ "BufRead", "BufNewFile" }, {
	pattern = "*.js",
	callback = function()
		local content = table.concat(vim.api.nvim_buf_get_lines(0, 0, -1, false), "\n")
		if content:find("<[%w]+") then
			vim.bo.filetype = "javascriptreact"
		end
	end,
})

-- =========================
-- 保存上次光标位置
-- =========================
vim.api.nvim_create_autocmd("BufReadPost", {
	pattern = "*",
	callback = function()
		local last_pos = vim.fn.line([['"]])
		if last_pos > 0 and last_pos <= vim.fn.line("$") then
			vim.cmd('normal! g`"')
		end
	end,
})

