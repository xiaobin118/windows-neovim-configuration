-- Neovide GUI: make background transparent and ensure colorscheme doesn't override it
-- Place this after your colorscheme() call (or at end of init.lua)
vim.g.neovide_opacity = 0.88 -- window opacity (0.0..1.0)

vim.g.neovide_theme = "auto" -- 'dark', 'light', 'auto'
-- vim.g.neovide_background_color = "#00000000"     -- #RRGGBBAA, AA=00 makes the background fully transparent
vim.o.guifont = "JetBrainsMono Nerd Font:h14" -- set to a font you have on Windows

-- Optional: small cursor vfx tweaks
vim.g.neovide_cursor_vfx_mode = "ripple" -- or "pixiedust", "sonicboom", "torpedo", "wireframe"
vim.g.neovide_cursor_animation_length = 0.09
vim.g.neovide_cursor_trail_size = 0.4
vim.g.neovide_refresh_rate = 90
vim.g.neovide_cursor_smooth_blink = false

-- Force transparent highlights after colorscheme loads
vim.cmd([[
    augroup NeovideForceTransparent
    autocmd!
    " Force main groups to have no gui background so the window shows through
    autocmd ColorScheme * ++once lua vim.api.nvim_set_hl(0, "Normal",       { bg = "none" })
    autocmd ColorScheme * ++once lua vim.api.nvim_set_hl(0, "NormalFloat",  { bg = "none" })
    autocmd ColorScheme * ++once lua vim.api.nvim_set_hl(0, "SignColumn",   { bg = "none" })
    autocmd ColorScheme * ++once lua vim.api.nvim_set_hl(0, "NvimTreeNormal",{ bg = "none" })
    autocmd ColorScheme * ++once lua vim.api.nvim_set_hl(0, "TelescopeNormal",{ bg = "none" })
    autocmd ColorScheme * ++once lua vim.api.nvim_set_hl(0, "Pmenu",         { bg = "none" })
    augroup END
    ]])

vim.g.neovide_floating_shadow = true
vim.g.neovide_floating_z_height = 10
vim.g.neovide_light_angle_degrees = 45
vim.g.neovide_light_radius = 5

vim.g.neovide_cursor_hack = false
vim.g.neovide_refresh_rate_idle = 5

function Neovide_fullscreen()
	if vim.g.neovide_fullscreen then
		vim.g.neovide_fullscreen = false
	else
		vim.g.neovide_fullscreen = true
	end
end

vim.api.nvim_set_keymap("n", "<F11>", ":lua Neovide_fullscreen()<CR>", { noremap = true, silent = true })

vim.g.neovide_window_blurred = true

-- Command mode paste
vim.api.nvim_set_keymap("c", "<C-v>", "<C-r>+", { noremap = true })
-- Terminal mode paste
vim.api.nvim_set_keymap("t", "<C-v>", '<C-\\><C-n>"+pa', { noremap = true })

local change_transparency = function(delta)
	vim.g.neovide_opacity_point = vim.g.neovide_opacity_point + delta
	vim.g.neovide_background_color = "#0f1117" .. alpha()
end
vim.keymap.set({ "n", "v", "o" }, "<D-]>", function()
	change_transparency(0.01)
end)
vim.keymap.set({ "n", "v", "o" }, "<D-[>", function()
	change_transparency(-0.01)
end)
